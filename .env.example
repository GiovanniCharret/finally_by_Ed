# FinAlly environment variables
# Copy this file to `.env` and fill in the values you need.

# Required for live LLM chat. Skip if you only run with LLM_MOCK=true.
OPENROUTER_API_KEY=

# Optional: Massive (Polygon.io) API key for real market data.
# Leave empty to use the built-in market simulator (recommended for demos).
MASSIVE_API_KEY=

# When "true", the backend returns deterministic mock LLM responses without
# calling OpenRouter. Useful for E2E tests and offline development.
LLM_MOCK=false
